rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && (
        request.auth.token.email == "allaouaboucheneb04@gmail.com"
        || (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true
        )
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        )
      );
    }
    match /admins/{uid} { allow read: if signedIn() && (request.auth.uid == uid || isAdmin()); allow write: if isAdmin(); }
    match /users/{uid} { allow read: if signedIn() && (request.auth.uid == uid || isAdmin()); allow create, update: if signedIn() && (request.auth.uid == uid || isAdmin()); allow delete: if isAdmin(); }
    match /lines/{id} { allow read: if true; allow write: if isAdmin(); }
    match /stops/{id} { allow read: if true; allow write: if isAdmin(); }
    match /vehicles/{id} { allow read: if true; allow create, delete: if isAdmin(); allow update: if isAdmin() || (signedIn() && request.resource.data.driverId == request.auth.uid); }
    match /reports/{id} { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /{document=**} { allow read, write: if false; }
  }
}
