rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function role() { return signedIn() && userDoc().exists() ? userDoc().data.role : 'guest'; }
    function admin() { return signedIn() && role() == 'admin'; }
    function driver() { return signedIn() && (role() == 'driver' || role() == 'admin'); }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || admin());
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && (request.auth.uid == uid || admin());
      allow delete: if admin();
    }

    match /lines/{id} {
      allow read: if true;
      allow create, update, delete: if admin();
    }

    match /stops/{id} {
      allow read: if true;
      allow create, update, delete: if admin();
    }

    match /vehicles/{id} {
      allow read: if true;
      allow create, delete: if admin();
      allow update: if admin() || (driver() && request.resource.data.driverId == request.auth.uid);
    }

    match /reports/{id} {
      allow read: if admin();
      allow create: if true;
      allow update, delete: if admin();
    }
  }
}
